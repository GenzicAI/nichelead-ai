# ── NicheLead AI environment ──
# Copy to .env.local and fill in. The app runs on mock data until these are set,
# so local development works with no configuration.

# Supabase (database + auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Automation — Zapier only. A single Catch Hook fans out to email + SMS + CRM.
NEXT_PUBLIC_ZAPIER_CATCH_HOOK_URL=

# Abacus.AI — AI lead scoring & enrichment (placeholder)
ABACUS_AI_API_KEY=
ABACUS_AI_DEPLOYMENT_ID=

# Resend — transactional email (placeholder; called via Zapier)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Twilio — SMS outreach (placeholder; called via Zapier)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Tawk.to — live chat widget (placeholder)
NEXT_PUBLIC_TAWKTO_PROPERTY_ID=
NEXT_PUBLIC_TAWKTO_WIDGET_ID=
